{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Harness: Open Streamlit App",
      "type": "shell",
      "command": "streamlit",
      "args": [
        "run",
        "streamlit_app.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Harness: Refresh Meeting",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "harness_model.cli",
        "refresh-meeting",
        "--meeting-code",
        "${input:meetingCode}",
        "--raw-dir",
        "data/raw",
        "--db",
        "data/harness.db",
        "--csv",
        "data/features/runner_features.csv",
        "--track-pars",
        "${input:trackParsPath}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Harness: Score Meeting",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "harness_model.cli",
        "score-meeting",
        "--csv",
        "data/features/runner_features.csv",
        "--meeting-code",
        "${input:meetingCode}",
        "--out-csv",
        "data/odds/${input:meetingCode}_odds.csv"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Harness: Refresh And Score Meeting",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Harness: Refresh Meeting",
        "Harness: Score Meeting"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "meetingCode",
      "type": "promptString",
      "description": "Meeting code to refresh or score",
      "default": "LM300326"
    },
    {
      "id": "trackParsPath",
      "type": "promptString",
      "description": "Full path to track pars JSON",
      "default": "C:\\Users\\Paul Mustica\\Desktop\\track_pars.json"
    }
  ]
}
