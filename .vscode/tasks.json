{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ingest Meeting",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "ingest-meeting",
        "--html", "data/raw/meeting_${input:meetingCode}.html",
        "--db", "data/harness.db"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Build Features",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "build-features",
        "--db", "data/harness.db",
        "--csv", "data/features/runner_features.csv",
        "--track-pars", "${input:trackParsPath}"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Score Meeting",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "score-meeting",
        "--csv", "data/features/runner_features.csv",
        "--meeting-code", "${input:meetingCode}"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Score and Publish",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "score-meeting",
        "--csv", "data/features/runner_features.csv",
        "--meeting-code", "${input:meetingCode}",
        "--db", "data/harness.db",
        "--publish"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Fetch Meeting",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "fetch-meeting",
        "--meeting-code", "${input:meetingCode}",
        "--out", "data/raw"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Fetch Results",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "fetch-results",
        "--meeting-code", "${input:meetingCode}",
        "--out", "data/raw"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Ingest Results",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "ingest-results",
        "--html", "data/raw/results_${input:meetingCode}.html",
        "--db", "data/harness.db"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Fetch Horses",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "fetch-horses",
        "--meeting-html", "data/raw/meeting_${input:meetingCode}.html",
        "--out", "data/raw/horses",
        "--horse-library", "data/horse_library/nsw"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Ingest Horses",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "ingest-horses",
        "--horse-dir", "data/raw/horses",
        "--db", "data/harness.db"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Fetch Driver Stats",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "harness_model.cli",
        "fetch-driver-stats",
        "--meeting-code", "${input:meetingCode}",
        "--db", "data/harness.db"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Full Pipeline (Ingest + Horses + Drivers + Features + Score)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Ingest Meeting",
        "Fetch Horses",
        "Ingest Horses",
        "Fetch Driver Stats",
        "Build Features",
        "Score Meeting"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "meetingCode",
      "type": "promptString",
      "description": "Meeting code (e.g. LM300326)",
      "default": "LM300326"
    },
    {
      "id": "trackParsPath",
      "type": "promptString",
      "description": "Full path to track pars JSON",
      "default": "C:\\Users\\Paul Mustica\\Desktop\\track_pars.json"
    }
  ]
}
